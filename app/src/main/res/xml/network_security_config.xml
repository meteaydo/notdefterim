<?xml version="1.0" encoding="utf-8"?>
<!--
  Üretimde sertifika sabitleme (certificate pinning) eklenmelidir.
  Şu an yalnızca açık metin trafiğini engelliyoruz.
-->
<network-security-config>
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
